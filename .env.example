# Horizon DevSecOps Portal - Environment Variables
# Copy this file to .env and fill in the values for your environment.

# Application
VITE_APP_TITLE=Horizon DevSecOps Portal

# API
VITE_API_BASE_URL=http://localhost:8080/api

# SSO / Authentication
VITE_SSO_ENABLED=false
VITE_SSO_CLIENT_ID=
VITE_SSO_AUTHORITY=

# Kafka
VITE_KAFKA_BROKER_URL=

# Dynatrace
VITE_DYNATRACE_API_URL=

# Splunk
VITE_SPLUNK_API_URL=

# Elastic
VITE_ELASTIC_API_URL=

# ServiceNow
VITE_SERVICENOW_API_URL=